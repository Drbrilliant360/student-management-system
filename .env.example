# Local development — copy to .env and adjust as needed.
# On Vercel, set these in Project Settings → Environment Variables.

# Django
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app
CSRF_TRUSTED_ORIGINS=https://*.vercel.app

# Vercel production (set in dashboard, not in .env)
# DJANGO_DEBUG=0
# VERCEL=1
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Database — leave unset locally to use SQLite
# DATABASE_URL=postgres://user:pass@localhost:5432/student_info_system

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# Redis / Celery (optional, not used on Vercel serverless)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
